<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="@drawable/shape_notif_cyber_bg"
    android:padding="8dp">

    <FrameLayout
        android:id="@+id/notif_color_block"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:background="@drawable/shape_notif_cyber_block">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="課"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:includeFontPadding="false"/>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/notif_color_block"
        android:layout_toStartOf="@+id/notif_status_tag"
        android:layout_centerVertical="true"
        android:layout_marginHorizontal="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notif_course_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="数据结构 (C++)"
            android:textColor="#00E5FF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/notif_course_room"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="[ 📍 E4-301 | 08:10 ]"
            android:textColor="#CC80FFFF"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"/>
    </LinearLayout>

    <TextView
        android:id="@+id/notif_status_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="@drawable/shape_notif_cyber_tag"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="进行中"
        android:textColor="#00E5FF"
        android:textSize="9sp"
        android:textStyle="bold"
        android:gravity="center"/>

</RelativeLayout>